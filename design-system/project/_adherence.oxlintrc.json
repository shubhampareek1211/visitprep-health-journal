{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/clinical/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/visitprep/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Public Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Public Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|caution|danger|positive)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'caution' | 'danger' | 'positive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|disabled|block|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, disabled, block, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|action|padding|children|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, eyebrow, action, padding, children, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='EvidenceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:signal|level|date|snippet|match|injectionAdjacent|style|key|ref|className|style|children)$/]",
        "message": "<EvidenceCard> doesn't accept that prop. Declared props: signal, level, date, snippet, match, injectionAdjacent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EvidenceCard'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:none|mild|moderate|severe)$/]",
        "message": "<EvidenceCard> level must be one of 'none' | 'mild' | 'moderate' | 'severe'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|icon|affix|error|size|id|value|onChange|placeholder|type|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, icon, affix, error, size, id, value, onChange, placeholder, type, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaTone|icon|hint|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, unit, delta, deltaTone, icon, hint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:neutral|positive|caution|danger)$/]",
        "message": "<KpiCard> deltaTone must be one of 'neutral' | 'positive' | 'caution' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|color|key|ref|className|style|children)$/]",
        "message": "<BarDatum> doesn't accept that prop. Declared props: label, value, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='SafetyNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|icon|style|key|ref|className|style|children)$/]",
        "message": "<SafetyNote> doesn't accept that prop. Declared props: tone, title, children, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SafetyNote'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:caution|danger|neutral)$/]",
        "message": "<SafetyNote> tone must be one of 'caution' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|width|height|color|fill|showEnd|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: values, width, height, color, fill, showEnd, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|size|pulse|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: level, size, pulse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:none|mild|moderate|severe)$/]",
        "message": "<StatusDot> level must be one of 'none' | 'mild' | 'moderate' | 'severe'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SymptomChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|level|count|injectionAdjacent|selected|onClick|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<SymptomChip> doesn't accept that prop. Declared props: label, level, count, injectionAdjacent, selected, onClick, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SymptomChip'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:none|mild|moderate|severe)$/]",
        "message": "<SymptomChip> level must be one of 'none' | 'mild' | 'moderate' | 'severe'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|value|onChange|placeholder|rows|maxLength|id|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint, value, onChange, placeholder, rows, maxLength, id, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|description|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, label, description, disabled, id, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
